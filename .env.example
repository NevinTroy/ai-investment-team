# Copy to .env and fill in your keys:
#   cp .env.example .env

# --- Required API keys ---
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
PRESENTON_API_KEY=

# --- LLM (committee agents + investment memo) ---
# Provider: anthropic (default) or openai
SUMMIT_LLM_PROVIDER=anthropic
SUMMIT_LLM_MODEL=claude-sonnet-4-6
SUMMIT_LLM_MAX_TOKENS=16384
SUMMIT_LLM_MEMO_MAX_TOKENS=64000

# Only needed when SUMMIT_LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_API_BASE=

# --- Presenton (investment memo PDF deck) ---
# Smart design ID from your Presenton account; leave empty to use PRESENTON_THEME instead
PRESENTON_SMART_DESIGN=990d88ea-9ca6-4a74-bc11-52cf55a993c9
PRESENTON_THEME=mint-blue
PRESENTON_EXPORT_AS=pdf
PRESENTON_TONE=default
PRESENTON_VERBOSITY=standard
PRESENTON_IMAGE_TYPE=ai-generated

# --- Optional: committee CLI debugging ---
# COMMITTEE_LOG_CONSOLE=1
# COMMITTEE_SHOW_REASONING=1

# --- Supabase (chat/agent-output/deck/network persistence) ---
# See supabase/schema.sql for the tables to create, and create a public
# Storage bucket named "decks". Use the service_role key (not anon) here —
# it is only ever read by the backend, never sent to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# The read-only SQL/data-retrieval agent (POST /api/query, e.g. "find me the
# fintech companies") reuses these same two variables via Supabase's REST API —
# its tools only ever read (.select()), so it can never modify the database.
